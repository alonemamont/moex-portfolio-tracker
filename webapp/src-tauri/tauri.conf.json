{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MOEX Portfolio Tracker",
  "version": "0.1.0",
  "identifier": "ru.alonemamont.moex-portfolio-tracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MOEX Portfolio Tracker",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://invest-public-api.tbank.ru https://api.finam.ru https://iss.moex.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": false
  }
}
